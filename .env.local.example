# Gemini API Key for AI color analysis
# Get your API key from: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your_api_key_here
# mxnzp APP ID & APP SECRET for mxnzp tools API
# Get your APP ID & APP SECRET from: https://www.mxnzp.com/
NEXT_PUBLIC_MXNZP_APP_ID=your_app_id_here
NEXT_PUBLIC_MXNZP_APP_SECRET=your_app_secret_here

# API Base URL for devtools-backend
NEXT_PUBLIC_API_BASE_URL=your_api_base_url_here


# ==========================================
# Created by Vercel CLI[用于GitHub Action]
# 获取 Vercel Token
# 1. 访问 vercel.com/account/tokens (https://vercel.com/account/tokens)
# 2. 点击 Create
# 3. 输入 Token 名称（如 github-actions）
# 4. 点击 Generate
# 5. 复制生成的 Token
# 申请地址：https://vercel.com/account/tokens
# ==========================================
VERCEL_TOKEN=your_vercel_oidc_token_here
